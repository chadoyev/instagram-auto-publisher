# ══════════════════════════════════════════════════
#  Instagram Auto Publisher — Configuration
# ══════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
ADMIN_IDS=123456789
BOT_MODE=polling
# For webhook mode:
# WEBHOOK_HOST=https://yourdomain.com
# WEBHOOK_PATH=/ig
# WEBHOOK_PORT=8081
# WEBHOOK_SECRET=any-random-string-here

# ── Instagram publishing ─────────────────────────
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
# IG_SESSION_PATH=session_data/session.json

# ── External APIs ────────────────────────────────
# HikerAPI for Instagram content download
HIKER_API_KEY=your_hiker_api_key
# TikTok download API (Douyin_TikTok_Download_API)
TIKTOK_API_URL=http://tiktok-api:80

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bot:bot@postgres:5432/bot
DB_NAME=bot
DB_USER=bot
DB_PASSWORD=bot

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Content settings ─────────────────────────────
DEFAULT_CAPTION=Подписывайся!
# WATERMARK_PATH=logo.png
# MAX_VIDEO_DURATION=240

# ── Schedule ─────────────────────────────────────
DAILY_RESET_TIME=00:00

# ── Docker Hub (for deployment) ──────────────────
# DOCKER_IMAGE=chadoyev/instagram-auto-publisher:latest

